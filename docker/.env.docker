# =====================================================
# LLM-TradeBot Docker 部署环境变量
# =====================================================
# 
# 使用方法：
# 1. 复制此文件为 .env.docker
# 2. 填入你的真实 API 密钥
# 3. 运行: docker-compose --env-file .env.docker up -d
#
# =====================================================

# -----------------------------------------------------
# Binance API 配置
# -----------------------------------------------------
# 测试网 (推荐先用测试网测试)
BINANCE_API_KEY=y3Cpeu8zzrI101Wdcxmeav6dGTemBVVG5UKItwXUA3W1w4pi53TpoytA6E9UyYT2
BINANCE_SECRET_KEY=TPYmPu4okaj0C55l3ZgcpZCyXyZ5xld6fd6OgrLKfLzrslmt5fJxzc4S11HzCyhw
BINANCE_TESTNET=false

# 实盘 (测试通过后切换)
# BINANCE_API_KEY=your_binance_mainnet_api_key
# BINANCE_SECRET_KEY=your_binance_mainnet_secret
# BINANCE_TESTNET=false

# -----------------------------------------------------
# LLM API 配置
# -----------------------------------------------------
# 选择 LLM 提供商 (默认: minimax)
LLM_PROVIDER=minimax

# MiniMax API (推荐 - 速度快)
MINIMAX_API_KEY=sk-cp-E_3U74fLnlUi77m29B_LNIa9QqH9qQRvwX2JfwyXH_NxyjKUq8RZFW86aDf7xWnCj33b9JyMUvr4wLiEMh52YAhIUYpFKdTuf3Zsa4dohQ-SPZ23FGgWQu0

# DeepSeek API (可选 - 成本低)
# DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI API (可选)
# OPENAI_API_KEY=your_openai_api_key

# 其他 LLM 提供商 (可选)
# CLAUDE_API_KEY=your_claude_api_key
# QWEN_API_KEY=your_qwen_api_key
# GEMINI_API_KEY=your_gemini_api_key
# KIMI_API_KEY=your_kimi_api_key
# GLM_API_KEY=your_glm_api_key

# -----------------------------------------------------
# 交易配置
# -----------------------------------------------------
# 交易币种 (逗号分隔)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# -----------------------------------------------------
# Quant API (可选)
# -----------------------------------------------------
# QUANT_AUTH_TOKEN=your_quant_api_token

# -----------------------------------------------------
# 数据库配置 (可选 - 默认使用 SQLite)
# -----------------------------------------------------
# PostgreSQL (用于生产环境)
# DATABASE_URL=postgresql://user:password@postgres:5432/tradebot

# Redis (使用 docker-compose 中的 Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------
# Web Dashboard 安全配置
# -----------------------------------------------------
# 访问密码 (默认: admin123)
WEB_PASSWORD=admin123
